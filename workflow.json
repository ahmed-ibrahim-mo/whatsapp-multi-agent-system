      "parameters": {
        "jsCode": "const text = items[0].json.output || \"\"; // جلب النص من الـ Node السابقة\n\n// وظيفة لاكتشاف إذا كان النص يحتوي على حروف عربية\nfunction isArabic(text) {\n    const arabicPattern = /[\\u0600-\\u06FF]/;\n    return arabicPattern.test(text);\n}\n\n// تحديد اللغة بناءً على فحص النص\nconst lang = isArabic(text) ? \"ar\" : \"en\";\n\nreturn [{\n    json: {\n        text: text,\n        lang: lang\n    }\n}];"
